# ============================================
# SAPATARIA MARTINELLI — Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e preencha os valores.

# --- Banco de dados ---
# Local (desenvolvimento): arquivo SQLite
DATABASE_URL="file:./dev.db"
# Produção (Turso - SQLite na nuvem): troque por isto quando subir
# DATABASE_URL="libsql://sapataria-martinelli.turso.io"
# TURSO_AUTH_TOKEN="seu-token-aqui"

# --- Autenticação do Admin (1 usuário) ---
ADMIN_USER="admin"
# Gere o hash em https://bcrypt-generator.com/ (rounds=10)
# ou rode: node -e "console.log(require('bcryptjs').hashSync('SUA_SENHA',10))"
# Padrão de fábrica: admin123
ADMIN_PASSWORD_HASH="$2a$10$KIXxKxJxJxJxJxJxJxJxJuO5rH7vKwF3W7sKpN5YxYxYxYxYxYxYxY"

# --- Sapataria ---
NEXT_PUBLIC_SAPATARIA_NOME="Sapataria Martinelli"
NEXT_PUBLIC_SAPATARIA_TELEFONE="+5527997048164"
NEXT_PUBLIC_SAPATARIA_WHATSAPP="5527997048164"
NEXT_PUBLIC_SAPATARIA_ENDERECO="Rua dos Evangélicos, 453 — Santa Maria de Jetibá/ES"
NEXT_PUBLIC_SAPATARIA_INSTAGRAM="martinellisapataria"
NEXT_PUBLIC_SAPATARIA_SITE_URL="http://localhost:3000"

# --- Cookie de sessão ---
SESSION_SECRET="troque-isto-por-uma-string-aleatoria-de-32-caracteres"
